    "dev:prod:tunnel": "cross-env EXPO_FORCE_WEBCONTAINER_ENV=1 EXPO_PUBLIC_API_ENV=production expo start --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
