    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "~7.11.0",
    "expo": "~55.0.17",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.11",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.14",
    "expo-linking": "~55.0.9",
    "expo-location": "~55.1.8",
