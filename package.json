    "expo-print": "~55.0.13",
    "expo-router": "~55.0.8",
    "expo-sharing": "~55.0.18",
    "expo-speech": "~55.0.13",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.5",
